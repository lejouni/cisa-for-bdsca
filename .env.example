# Black Duck Configuration
BLACKDUCK_URL=https://your-instance.blackduck.com
BLACKDUCK_API_TOKEN=your_api_token_here
BLACKDUCK_VERIFY_SSL=true

# Output Configuration (optional)
OUTPUT_PATH=./output

# EUVD Cache Configuration (optional)
# Location where EUVD-to-CVE mapping CSV will be cached
EUVD_CACHE_DIR=~/.cache/cisa-bdsca

# Logging (optional)
LOG_LEVEL=INFO
